  "config": {
    "alpha": 0.1,
    "default_prompt": "Build a SaaS landing page for 'StackBrief' \u2014 an AI tool that generates executive summaries from long Slack threads and email chains. The page needs a hero with a demo animation placeholder, a 'Before/After' section showing messy threads vs clean summary, 3 feature cards with micro-illustrations, a testimonial carousel section, and a 'Get Early Access' CTA. Use a clean white background with indigo and orange accents. Feel modern and developer-friendly."
  },
  "anchor": {
    "id": "eef0b3c8",
    "completion": "<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>StackBrief | Executive AI Summaries</title>\n    \n    <!-- Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,300..700&family=JetBrains+Mono:wght@100..800&display=swap\" rel=\"stylesheet\">\n    \n    <!-- Tailwind CSS -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\"></script>\n\n    <style>\n        /* Custom Aesthetic Variables */\n        :root {\n            --font-display: 'JetBrains Mono', monospace;\n            --font-body: 'Inter', sans-serif;\n            --color-indigo-600: #4F46E5;\n            --color-indigo-700: #4338ca;\n            --color-orange-500: #F97316;\n            --color-bg-dark: #0B0D17; /* Used for contrast in hero */\n        }\n\n        body {\n            font-family: var(--font-body);\n            background-color: #FFFFFF;\n            color: #0F172A;\n            -webkit-font-smoothing: antialiased;\n            overflow-x: hidden;\n        }\n\n        /* Typography Overrides */\n        h1, h2, h3 { font-family: var(--font-display); letter-spacing: -0.04em; line-height: 1.1; }\n        \n        /* Utility Classes */\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.8);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.6);\n        }\n\n        .gradient-text {\n            background: linear-gradient(90deg, var(--color-indigo-700), #8B5CF6, var(--color-orange-500));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n\n        /* Custom Animations */\n        @keyframes float {\n            0% { transform: translateY(0px); }\n            50% { transform: translateY(-12px); }\n            100% { transform: translateY(0px); }\n        }\n\n        .animate-float {\n            animation: float 4s ease-in-out infinite;\n        }\n\n        @keyframes pulse-slow {\n            0%, 100% { opacity: 1; }\n            50% { opacity: 0.7; }\n        }\n\n        .animate-pulse-slow {\n            animation: pulse-slow 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n        }\n\n        /* Noise Texture Overlay */\n        .noise-overlay {\n            position: fixed;\n            top: 0; left: 0; width: 100%; height: 100%;\n            pointer-events: none;\n            z-index: 50;\n            opacity: 0.03;\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='1'/%3E%3C/svg%3E\");\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #f1f1f1; }\n        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }\n    </style>\n\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        brand: {\n                            indigo: '#4F46E5',\n                            orange: '#F97316'\n                        }\n                    },\n                    fontFamily: {\n                        mono: ['\"JetBrains Mono\"', 'monospace'],\n                    }\n                }\n            }\n        }\n    </script>\n</head>\n<body class=\"antialiased\">\n\n    <!-- Noise Texture -->\n    <div class=\"noise-overlay\"></div>\n\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 w-full z-40 transition-all duration-300 border-b border-gray-100\" id=\"navbar\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n            <!-- Logo -->\n            <a href=\"#\" class=\"flex items-center gap-2 group\" onclick=\"window.scrollTo(0,0)\">\n                <div class=\"w-8 h-8 bg-gradient-to-br from-brand-indigo to-brand-orange rounded-lg flex items-center justify-center text-white font-mono text-sm font-bold shadow-lg\">\n                    SB\n                </div>\n                <span class=\"font-display font-bold text-xl tracking-tight group-hover:text-brand-indigo transition-colors\">StackBrief</span>\n            </a>\n\n            <!-- Desktop Nav -->\n            <div class=\"hidden md:flex items-center gap-8\">\n                <a href=\"#how-it-works\" class=\"text-sm font-medium text-gray-500 hover:text-black transition-colors\">How it Works</a>\n                <a href=\"#features\" class=\"text-sm font-medium text-gray-500 hover:text-black transition-colors\">Features</a>\n                <a href=\"#pricing\" class=\"text-sm font-medium text-gray-500 hover:text-black transition-colors\">Pricing</a>\n            </div>\n\n            <!-- CTA -->\n            <div class=\"hidden md:flex items-center gap-4\">\n                <button class=\"text-sm font-semibold text-brand-indigo hover:underline\">Login</button>\n                <button onclick=\"scrollToSection('cta')\" class=\"bg-gray-900 text-white px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider hover:bg-black transition-transform active:scale-95 shadow-lg hover:shadow-brand-indigo/20\">\n                    Get Early Access\n                </button>\n            </div>\n\n            <!-- Mobile Menu Btn -->\n            <button class=\"md:hidden text-gray-600\" onclick=\"document.getElementById('mobile-menu').classList.toggle('hidden')\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-6 h-6\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3.75 9h16.5m-16.5 6.75h16.5\" />\n                </svg>\n            </button>\n        </div>\n\n        <!-- Mobile Menu -->\n        <div id=\"mobile-menu\" class=\"hidden md:hidden bg-white border-t border-gray-100 absolute w-full p-6\">\n            <div class=\"flex flex-col gap-4 text-center\">\n                <a href=\"#\" class=\"text-sm font-medium text-gray-600 hover:text-black\">How it Works</a>\n                <a href=\"#\" class=\"text-sm font-medium text-gray-600 hover:text-black\">Features</a>\n                <button onclick=\"scrollToSection('cta')\" class=\"bg-brand-indigo text-white px-4 py-2 rounded-md text-sm font-bold\">Get Early Access</button>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden\">\n        <!-- Background Gradients -->\n        <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-gradient-to-b from-brand-indigo/20 to-transparent blur-3xl rounded-full opacity-60 pointer-events-none\"></div>\n        <div class=\"absolute bottom-0 right-0 w-[600px] h-[400px] bg-gradient-to-t from-brand-orange/10 to-transparent blur-3xl rounded-full opacity-50 pointer-events-none\"></div>\n\n        <div class=\"max-w-7xl mx-auto px-6 relative z-10 text-center\">\n            \n            <!-- Badge -->\n            <div class=\"inline-flex items-center gap-2 mb-8 animate-fade-in-up\" style=\"animation-delay: 0.1s\">\n                <span class=\"px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-[10px] font-mono uppercase tracking-widest text-brand-indigo\">\n                    New: Slack Integration v2.0\n                </span>\n            </div>\n\n            <h1 class=\"text-5xl lg:text-7xl mb-6 leading-tight max-w-4xl mx-auto animate-fade-in-up\" style=\"animation-delay: 0.3s\">\n                Turn endless threads into <br/> \n                <span class=\"gradient-text font-bold\">clarity.</span>\n            </h1>\n\n            <p class=\"text-lg lg:text-xl text-gray-500 mb-10 max-w-2xl mx-auto animate-fade-in-up\" style=\"animation-delay: 0.5s\">\n                The AI executive assistant built for Slack and Email. \n                It digests hours of context in seconds so you can make decisions, not scroll feeds.\n            </p>\n\n            <!-- Hero Demo Animation Placeholder -->\n            <div class=\"relative max-w-4xl mx-auto mb-16 animate-fade-in-up\" style=\"animation-delay: 0.8s\">\n                <div class=\"glass-panel rounded-xl p-2 shadow-2xl border-gray-200/50\">\n                    <!-- Fake Window Header -->\n                    <div class=\"flex items-center gap-3 px-4 py-3 bg-white rounded-t-lg mb-1 border-b border-gray-100\">\n                        <div class=\"w-3 h-3 rounded-full bg-red-400\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-yellow-400\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-green-400\"></div>\n                    </div>\n\n                    <!-- The \"Before\" (Messy) -->\n                    <div id=\"before-content\" class=\"bg-gray-50 p-6 h-[320px] flex flex-col gap-3 font-mono text-sm overflow-hidden relative\">\n                        <!-- JS will populate this with fake messy data -->\n                    </div>\n\n                    <!-- The \"After\" (Summary) - Hidden initially or overlaid? Let's do an overlay effect -->\n                    <div id=\"after-content\" class=\"hidden absolute inset-0 bg-white/95 backdrop-blur-sm p-6 flex flex-col gap-4 overflow-y-auto animate-slide-up\">\n                        <span class=\"text-xs font-bold text-brand-orange uppercase tracking-widest mb-1 block\">Analysis Complete</span>\n                        \n                        <!-- Key Action -->\n                        <div class=\"bg-blue-50 border-l-4 border-brand-indigo p-4 rounded-r-lg flex justify-between items-start gap-4\">\n                            <div>\n                                <h3 class=\"font-bold text-gray-900\">Q3 Roadblock</h3>\n                                <p class=\"text-xs text-gray-500 mt-1\">Project X is delayed due to API latency issues identified in the PR reviews.</p>\n                            </div>\n                            <span class=\"text-[10px] bg-white border px-2 py-0.5 rounded font-mono\">Action Required</span>\n                        </div>\n\n                        <!-- Key Insight -->\n                        <div class=\"bg-orange-50 border-l-4 border-brand-orange p-3 rounded-r-lg\">\n                            <p class=\"text-sm text-gray-700\">Team @design has requested a 2-day buffer to refactor the auth pipeline.</p>\n                        </div>\n\n                        <!-- Quick Stats -->\n                        <div class=\"grid grid-cols-2 gap-4 mt-1 pt-3 border-t border-gray-100\">\n                            <div class=\"flex items-center gap-2\">\n                                <svg class=\"w-4 h-4 text-brand-indigo\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\"></path></svg>\n                                <span class=\"text-xs font-mono text-gray-500\">12h Context Processed</span>\n                            </div>\n                            <div class=\"flex items-center gap-2\">\n                                <svg class=\"w-4 h-4 text-brand-orange\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                                <span class=\"text-xs font-mono text-gray-500\">5 Action Items</span>\n                            </div>\n                        </div>\n\n                    </div>\n\n                    <!-- Magic Trigger Line (Visual only) -->\n                    <div id=\"magic-line\" class=\"absolute top-1/2 left-0 w-full h-[2px] bg-brand-indigo/50 -translate-y-1/2 pointer-events-none\"></div>\n                </div>\n            </div>\n\n            <!-- Hero Buttons -->\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up\" style=\"animation-delay: 1.2s\">\n                <button onclick=\"scrollToSection('cta')\" class=\"px-8 py-3.5 bg-brand-indigo text-white font-mono font-bold rounded-lg shadow-[0_4px_20px_-4px_rgba(79,70,229,0.3)] hover:shadow-[0_6px_24px_-4px_rgba(79,70,229,0.4)] transition-all active:scale-95\">\n                    Start Generating Free\n                </button>\n                <div class=\"flex items-center gap-2 text-sm text-gray-400 font-mono\">\n                    <svg class=\"w-4 h-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M15.963 8.917a9 9 0 0 1-5.66 8.26 8.2 8.2 0 0 0-1.732-1.72A7.46 7.46 0 0 1 4.532 2.3a9.9 9.9 0 0 1 6.123 6.617zM8.648 7.97a9.8 9.8 0 0 1 6.98-5.82A10 10 0 0 1 8.65 7.97z\"/></svg>\n                    <span>No credit card required</span>\n                </div>\n            </div>\n\n        </div>\n    </section>\n\n    <!-- The Problem / Visual Divider -->\n    <section class=\"py-12 bg-gray-50 border-y border-gray-200\">\n        <div class=\"max-w-7xl mx-auto px-6 text-center mb-8\">\n            <h3 class=\"text-lg font-display text-gray-900 tracking-tight\">Stop managing context, start making decisions</h3>\n        </div>\n    </section>\n\n    <!-- Features Section (Bento Grid) -->\n    <section id=\"features\" class=\"py-24 relative overflow-hidden\">\n        <!-- Decoration Circle -->\n        <div class=\"absolute top-1/2 left-0 w-[500px] h-[500px] bg-brand-indigo/5 rounded-full blur-3xl -translate-y-1/2 pointer-events-none\"></div>\n\n        <div class=\"max-w-7xl mx-auto px-6 relative z-10\">\n            <div class=\"text-center mb-16\">\n                <h2 class=\"text-3xl lg:text-4xl font-bold mb-4\">Designed for <span class=\"text-brand-indigo font-mono text-base opacity-70\">high velocity</span> teams.</h2>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                \n                <!-- Card 1: Slack Integration -->\n                <div class=\"group relative bg-white rounded-2xl border border-gray-200 p-8 hover:border-brand-indigo/50 transition-colors duration-300 shadow-lg hover:shadow-xl\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-16 h-1 bg-gradient-to-r from-transparent via-brand-orange to-transparent rotate-90 opacity-50\"></div>\n                    <div class=\"mb-8 flex justify-center text-gray-300 group-hover:text-brand-indigo transition-colors\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-10 h-10\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6.75 7.5l3 2.25-3 2.25m4.98-.75L15.75 15h3.375c1.26 0 2.25-.99 2.25-2.25v-2.25l-3.375-2.25Zm0 12.75l-3-2.25 3-2.25m4.98 0L21.75 12h-3.375c-1.26 0-2.25-.99-2.25-2.25v-2.25l3.375-2.25Z\" />\n                        </svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Slack Threads</h3>\n                    <p class=\"text-gray-500 leading-relaxed mb-6\">Paste a messy thread URL. We extract the core conflict, timelines, and assignee updates.</p>\n                    \n                    <!-- Micro Illustration -->\n                    <div class=\"relative h-[200px] bg-gradient-to-b from-indigo-50 to-white rounded-lg flex items-end p-4 overflow-hidden\">\n                        <div class=\"w-full max-w-xs font-mono text-[10px] text-gray-600 leading-relaxed animate-pulse-slow opacity-70\">\n                            <span class=\"text-brand-indigo block mb-1\">// thread:Zx92</span>\n                            <span class=\"block\"><b>// user@jane:</b> Can we move the deadline?</span><br>\n                            <span class=\"block text-gray-400\"><b>// bot@ai:</b> Analyzing context...</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Card 2: Email Chains -->\n                <div class=\"group relative bg-white rounded-2xl border border-gray-200 p-8 hover:border-brand-indigo/50 transition-colors duration-300 shadow-lg hover:shadow-xl\">\n                    <div class=\"mb-6 flex justify-center text-orange-500 group-hover:text-brand-orange transition-colors\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-8 h-8 opacity-60 group-hover:opacity-100 transition-opacity\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.06 1.986l-7.5 4.532a2.25 2.25 0 01-2.36 0L3.32 12.48a2.25 2.25 0 01-1.06-1.986V6.75\" />\n                        </svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Email Chains</h3>\n                    <p class=\"text-gray-500 leading-relaxed mb-6\">The \"I don't know where the conversation went\" problem is solved. Get the single source of truth.</p>\n\n                    <!-- Micro Illustration -->\n                    <div class=\"relative h-[200px] bg-gray-900 rounded-lg flex items-center justify-center overflow-hidden border border-gray-800\">\n                        <div class=\"absolute inset-y-0 left-0 w-1/3 bg-white opacity-5 transform -skew-x-12\"></div>\n                        <span class=\"relative z-10 text-white font-mono text-xs uppercase tracking-widest\">Context Extracted</span>\n                    </div>\n                </div>\n\n                <!-- Card 3: AI Summary -->\n                <div class=\"group relative bg-gray-900 rounded-2xl border border-gray-800 p-8 hover:border-brand-indigo transition-colors duration-300 shadow-xl\">\n                    <div class=\"absolute top-1/2 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-brand-orange to-transparent rotate-90 opacity-50\"></div>\n                    \n                    <h3 class=\"text-xl font-bold text-white mb-3 flex items-center gap-2\">\n                        <span class=\"w-2 h-2 rounded-full bg-green-400 animate-pulse\"></span>\n                        AI Executive Summary\n                    </h3>\n                    <p class=\"text-gray-400 leading-relaxed mb-6 font-light\">We don't just summarize; we prioritize. The output is structured with actionable items, risk flags, and decision points.</p>\n\n                    <!-- Mock Terminal Output -->\n                    <div class=\"bg-black/50 rounded-lg p-4 font-mono text-xs border border-gray-800 overflow-hidden\">\n                        <span class=\"text-green-400\">$ run brief.py --input raw_data.json</span><br>\n                        &gt; Generating...<br>\n                        &gt; <strong>Decision Required:</strong> Approve Q3 Budget? (70% Support)</div>\n                        \n                    <!-- Visual Decoration -->\n                     <div class=\"absolute -bottom-10 -right-10 w-32 h-32 bg-brand-indigo/30 blur-xl rounded-full\"></div>\n                </div>\n\n            </div>\n        </div>\n    </section>\n\n    <!-- Testimonial Carousel (Simplified) -->\n    <section class=\"py-24 overflow-hidden relative\">\n        <div class=\"max-w-7xl mx-auto px-6 flex items-end justify-center gap-10 md:gap-20\">\n            <!-- Card 1 -->\n            <div class=\"w-full max-w-md bg-white border border-gray-100 p-8 rounded-lg shadow-xl relative group\">\n                <div class=\"absolute -top-4 right-6 text-brand-orange opacity-20 font-mono text-xs uppercase tracking-widest\">Verified</div>\n                <p class=\"text-gray-700 italic mb-6 pt-4 pr-8\">\"We used to spend 30 minutes on Monday morning reading emails. Now we get the StackBrief and dive straight into implementation.\" \u2014 Sarah L, CTO @ TechFlow</p>\n            </div>\n            \n            <!-- Card 2 -->\n             <div class=\"w-full max-w-md bg-white border border-gray-100 p-8 rounded-lg shadow-xl relative group opacity-50 translate-y-8 md:translate-y-[4rem]\">\n                <div class=\"absolute -top-4 right-6 text-brand-orange opacity-20 font-mono text-xs uppercase tracking-widest\">Verified</div>\n                <p class=\"text-gray-700 italic mb-6 pt-4 pr-8\">\"It's the only tool that actually understands Slack thread context without hallucinating a meeting.\" \u2014 Mike R, Product Lead @ StartUp.io</p>\n            </div>\n\n             <!-- Card 3 -->\n             <div class=\"w-full max-w-md bg-white border border-gray-100 p-8 rounded-lg shadow-xl relative group opacity-50 translate-y-8 md:translate-y-[4rem]\">\n                <div class=\"absolute -top-4 right-6 text-brand-orange opacity-20 font-mono text-xs uppercase tracking-widest\">Verified</div>\n                <p class=\"text-gray-700 italic mb-6 pt-4 pr-8\">\"Clean. Fast. Finally an AI tool that respects my time instead of wasting it on 'generating' fluff.\" \u2014 Alex D, Engineer @ ScaleUp</p>\n            </div>\n\n        </div>\n    </section>\n\n    <!-- CTA Section -->\n    <section id=\"cta\" class=\"py-20 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto px-6 text-center\">\n            <h2 class=\"text-3xl lg:text-5xl font-bold mb-6 tracking-tight\">Ready to reclaim your afternoon?</h2>\n            <p class=\"text-gray-500 text-lg mb-10 max-w-xl mx-auto\">Join 5,000+ teams cutting meeting time by 40% with StackBrief. Free for the first week.</p>\n            \n            <button onclick=\"scrollToSection('form')\" class=\"inline-flex items-center gap-3 px-8 py-4 bg-brand-indigo text-white font-mono font-bold rounded-full shadow-lg hover:bg-brand-orange transition-colors duration-300\">\n                Get Early Access\n                <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-5 h-5\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3\" />\n                </svg>\n            </button>\n\n            <form class=\"mt-8 max-w-md mx-auto bg-white p-1 rounded-lg border border-gray-200 shadow-sm\">\n                <input type=\"email\" placeholder=\"Enter your email address\" class=\"block w-full px-4 py-3 text-gray-900 focus:ring-brand-indigo focus:border-brand-indigo rounded-md sm:text-sm bg-transparent outline-none placeholder-gray-400 border-b border-gray-200\">\n            </form>\n        </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"bg-white pt-16 pb-8 border-t border-gray-100\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 mb-12\">\n            <div class=\"flex items-center gap-2\">\n                <div class=\"w-6 h-6 bg-brand-indigo rounded-md flex items-center justify-center text-white font-mono text-[10px]\">SB</div>\n                <span class=\"font-display font-bold text-lg tracking-tight\">StackBrief</span>\n            </div>\n            <p class=\"text-sm text-gray-400\">\u00a9 2023 StackBrief Inc. All rights reserved.</p>\n        </div>\n    </footer>\n\n    <!-- Scripts -->\n    <script>\n        // Dynamic Content Generation for \"Before/After\" Demo\n        function populateHero() {\n            const beforeContainer = document.getElementById('before-content');\n            \n            // Simulating a messy thread dump\n            const messages = [\n                { text: \"@jane Design team, are we sure the Figma file is synced?\", time: \"10:02 AM\", color: \"bg-gray-50 border-gray-100\" },\n                { text: \"@devs Yes, but it's on a dev branch.\", time: \"10:03 AM\", color: \"bg-gray-100 border-gray-200\" },\n                { text: \"@jane Okay. Also @sales is complaining about the new logo colors again.\", time: \"10:04 AM\", color: \"bg-white border-gray-100\" },\n                { text: \"@design Team? I can't see the attachment.\", time: \"10:05 AM\", color: \"bg-white border-gray-200\" },\n                { text: \"@jane Check the Dropbox link. It's public now.\", time: \"10:06 AM\", color: \"bg-gray-50 border-gray-100\" },\n                 { text: \"@devs Does the API key work for Prod?\", time: \"10:07 AM\", color: \"bg-white border-gray-200\" },\n            ];\n\n            let html = '';\n            messages.forEach(msg => {\n                // Randomize line height slightly to look organic\n                const lh = Math.floor(Math.random() * 30) + 16; \n                html += `\n                    <div class=\"flex gap-4 items-start ${msg.color} opacity-50 blur-[0.5px]\">\n                        <div class=\"w-8 h-8 rounded-full bg-gray-200 flex-shrink-0\"></div>\n                        <div class=\"w-full\">\n                            <p class=\"font-mono text-xs mb-1\">\u2022 ${msg.time}</p>\n                            <span class=\"leading-tight break-all\">${msg.text}</span>\n                        </div>\n                    </div>\n                `;\n            });\n            \n            beforeContainer.innerHTML = html;\n\n            // Trigger \"Magic\" after a short delay to simulate AI working\n            setTimeout(() => {\n                const magicLine = document.getElementById('magic-line');\n                \n                // Simple animation sequence\n                magicLine.style.transition = 'transform 1s ease';\n                magicLine.style.transform = 'translateY(-50%)';\n                \n                setTimeout(() => {\n                    beforeContainer.classList.add('hidden', 'blur-xl');\n                    const afterContent = document.getElementById('after-content');\n                    afterContent.classList.remove('hidden');\n                    \n                    // Reset animation\n                    magicLine.style.transition = ''; \n                }, 1200);\n\n            }, 4000);\n        }\n\n        function scrollToSection(id) {\n            const element = document.getElementById(id);\n            if(element) {\n                element.scrollIntoView({ behavior: 'smooth' });\n            }\n        }\n\n        // Initialize on load\n        document.addEventListener('DOMContentLoaded', populateHero);\n    </script>\n</body>\n</html>"
  },
