  "config": {
    "alpha": 0.3,
    "default_prompt": "Build a premium landing page for 'Veloce' \u2014 a smart electric scooter subscription service. The page should have a hero section with a bold tagline and a 'Start Riding' CTA, a 3-step how-it-works section, a pricing section with 3 tiers (Starter, Pro, Unlimited), social proof with user avatars and a star rating, and a minimal footer. Use a dark background with neon green accents. Make it feel sleek and urban."
  },
  "anchor": {
    "id": "70f58d9d",
    "completion": "<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Veloce | The Future of Urban Mobility</title>\n    \n    <!-- Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Syne:wght@400;700;800&display=swap\" rel=\"stylesheet\">\n\n    <!-- Tailwind & Scripts -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    \n    <script>\n        tailwind.config = {\n            darkMode: 'class',\n            theme: {\n                extend: {\n                    colors: {\n                        'veloce-black': '#050505',\n                        'veloce-dark-gray': '#121214',\n                        'veloce-neon': '#ccff00',\n                        'veloce-red': '#ff3c00',\n                    },\n                    fontFamily: {\n                        sans: ['Syne', 'sans-serif'],\n                        mono: ['Space Grotesk', 'monospace'],\n                    },\n                    backgroundImage: {\n                        'grid-pattern': \"linear-gradient(to right, #1a1a1a 1px, transparent 1px), linear-gradient(to bottom, #1a1a1a 1px, transparent 1px)\",\n                    }\n                }\n            }\n        }\n    </script>\n\n    <style>\n        body {\n            background-color: #050505;\n            color: #ffffff;\n            cursor: none; /* Hiding default cursor for custom one */\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar {\n            width: 8px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #050505; \n        }\n        ::-webkit-scrollbar-thumb {\n            background: #333; \n        }\n        ::-webkit-scrollbar-thumb:hover {\n            background: #ccff00; \n        }\n\n        /* Custom Cursor */\n        .cursor-dot,\n        .cursor-outline {\n            position: fixed;\n            top: 0;\n            left: 0;\n            transform: translate(-50%, -50%);\n            border-radius: 50%;\n            z-index: 9999;\n            pointer-events: none;\n        }\n\n        .cursor-dot {\n            width: 8px;\n            height: 8px;\n            background-color: #ccff00;\n        }\n\n        .cursor-outline {\n            width: 40px;\n            height: 40px;\n            border: 1px solid rgba(204, 255, 0, 0.5);\n            transition: width 0.2s, height 0.2s;\n        }\n\n        /* Utility Classes for Layout */\n        .text-outline {\n            -webkit-text-stroke: 1px rgba(255,255,255,0.2);\n        }\n\n        /* Grid Background Effect */\n        .bg-grid {\n            background-size: 40px 40px;\n            mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);\n            -webkit-mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);\n        }\n\n        /* Gradient Text */\n        .gradient-text {\n            background: linear-gradient(135deg, #ffffff 0%, #666 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        /* Glass Card */\n        .glass-card {\n            background: rgba(20, 20, 25, 0.7);\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        /* Hover Glow Effect */\n        .glow-hover:hover {\n            box-shadow: 0 0 30px rgba(204, 255, 0, 0.3);\n        }\n\n        /* Image Reveal Mask */\n        .reveal-img {\n            mask-image: linear-gradient(to bottom, transparent 60%, black 100%);\n            -webkit-mask-image: linear-gradient(to bottom, transparent 60%, black 100%);\n        }\n    </style>\n</head>\n<body class=\"overflow-x-hidden\">\n\n    <!-- Custom Cursor Elements -->\n    <div class=\"cursor-dot\"></div>\n    <div class=\"cursor-outline\"></div>\n\n    <!-- Background Grid Overlay -->\n    <div class=\"fixed inset-0 bg-grid-pattern bg-opacity-20 pointer-events-none z-[-1]\" style=\"transform: rotate(-5deg);\"></div>\n    \n    <!-- Noise Texture Overlay for grit -->\n    <div class=\"fixed inset-0 opacity-[0.03] z-[-1] pointer-events-none\" style=\"background-image:url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI1MDAiIGhlaWdodD0iNTAwIj48dGV4dCB4PSIyNTAlIiB5PSIyNTAlIiBmb250LXNpemU9IjQiIGRvbGwvdHJhbnQgaWRnZW1lbnQ9InJvdW5kIiBzdHJva2U9ImJsYWNrIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIj48L3RleHQ+PC9zdmc+');\"></div>\n\n    <!-- Header -->\n    <nav class=\"fixed w-full z-50 px-6 py-6 flex justify-between items-center mix-blend-difference text-white\">\n        <a href=\"#\" class=\"text-2xl font-bold tracking-tighter hover:text-[#ccff00] transition-colors duration-300 relative group\" onmouseover=\"this.classList.add('glow-hover')\" onmouseout=\"this.classList.remove('glow-hover')\">\n            VELOCE<span class=\"text-xs align-top ml-1 opacity-50\">///</span>\n        </a>\n\n        <div class=\"hidden md:flex space-x-8 font-mono text-sm uppercase tracking-widest\">\n            <a href=\"#how\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('how')\">How It Works</a>\n            <a href=\"#pricing\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('pricing')\">Pricing</a>\n            <a href=\"#join\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('join')\">Join Now</a>\n        </div>\n\n        <button class=\"md:hidden text-xl font-mono\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-8 h-8 hover:text-[#ccff00] transition-colors\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5\" />\n            </svg>\n        </button>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"relative h-screen flex items-center justify-center overflow-hidden\">\n        \n        <!-- Abstract Background Element (Sleek Shape) -->\n        <div class=\"absolute top-1/4 right-[10%] w-[500px] h-[500px] bg-gradient-to-br from-[#ccff00]/20 to-transparent rounded-full blur-3xl animate-pulse\"></div>\n        \n        <!-- Hero Content -->\n        <div class=\"relative z-10 text-center px-4 max-w-6xl mx-auto\">\n            \n            <span class=\"inline-block py-1 px-3 border border-[#ccff00] rounded-full bg-black/50 backdrop-blur-sm mb-8 font-mono text-xs tracking-[0.2em] text-[#ccff00] uppercase animate-fade-in-up\">\n                City Access v4.0 Released\n            </span>\n\n            <h1 class=\"text-6xl md:text-9xl font-extrabold tracking-tight leading-none mb-8 mix-blend-difference text-white relative\">\n                <div class=\"overflow-hidden relative inline-block\">\n                    <span class=\"absolute transform -translate-y-full group-hover:animate-slide-up transition-transform duration-300\">GO.</span>\n                    <h1 class=\"relative z-10 drop-shadow-[0_4px_6px_rgba(255,255,255,0.1)]\">THE FUTURE</h1>\n                </div>\n            </h1>\n\n            <p class=\"text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 font-light tracking-wide leading-relaxed animate-fade-in-up delay-100\" style=\"animation-delay: 0.1s;\">\n                High-speed electric mobility for the urban explorer. \n                <span class=\"text-[#ccff00] font-mono\">Zero emissions.</span> Zero latency. Pure velocity.\n            </p>\n\n            <!-- CTA Button with Magnetic Effect -->\n            <div id=\"cta-container\" class=\"animate-fade-in-up delay-200 inline-block\" style=\"animation-delay: 0.2s;\">\n                <button onclick=\"scrollToId('pricing')\" onmouseenter=\"createHoverEffect()\" onmouseleave=\"clearHoverEffect()\">\n                    START RIDING\n                    <span class=\"ml-2 font-mono text-[#ccff00]\">[ENTER SYSTEM]</span>\n                </button>\n            </div>\n\n            <!-- Scroll Indicator -->\n            <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60 animate-bounce-slow\">\n                <span class=\"text-xs font-mono uppercase tracking-widest\">Scroll</span>\n                <div class=\"w-[1px] h-12 bg-gradient-to-b from-[#ccff00] to-transparent\"></div>\n            </div>\n        </div>\n    </section>\n\n    <!-- How It Works (3 Steps) -->\n    <section id=\"how\" class=\"py-24 px-6 md:px-12 max-w-screen-xl mx-auto relative\">\n        \n        <!-- Section Header -->\n        <div class=\"flex items-center gap-4 mb-16 border-b border-gray-800 pb-4\">\n            <span class=\"font-mono text-[#ccff00] font-bold text-sm uppercase\">Process</span>\n            <div class=\"w-[1px] h-8 bg-gradient-to-b from-[#333] to-transparent\"></div>\n        </div>\n\n        <div class=\"grid md:grid-cols-3 gap-x-12 relative\">\n            \n            <!-- Connecting Line (Desktop) -->\n            <div class=\"hidden md:block absolute top-8 left-[140px] right-[140px] h-[2px] bg-gradient-to-r from-[#1a1a1a] via-[#333] to-[#1a1a1a]\"></div>\n\n            <!-- Step 1 -->\n            <div class=\"group relative z-10\">\n                <div class=\"w-24 h-24 mx-auto glass-card rounded-xl flex items-center justify-center border-t border-l border-[#ccff00]/30 group-hover:border-[#ccff00] transition-colors duration-500 mb-8 relative overflow-hidden bg-black/60\">\n                    <span class=\"font-mono text-[10px] text-gray-400 absolute top-2 left-2\">STEP 01</span>\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"#ffffff\" class=\"w-8 h-8 group-hover:scale-110 transition-transform duration-300\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 7.5L3 12m0 0l6 4.5M15 12h6m0 0l-6-4.5M6 18v-7.5a2.25 2.25 0 012.25-2.25h9A2.25 2.25 0 0120 10.5v7.5a2.25 2.25 0 01-2.25 2.25H8.25A2.25 2.25 0 016 18z\" />\n                    </svg>\n                </div>\n                <h3 class=\"text-xl font-bold mb-4 text-white group-hover:text-[#ccff00] transition-colors\">Select Location</h3>\n                <p class=\"text-gray-500 leading-relaxed group-hover:leading-tight transition-all duration-300 max-w-xs mx-auto\">\n                    Use our AR interface to spot the nearest idle unit and initiate a 4-second proximity scan.\n                </p>\n            </div>\n\n            <!-- Step 2 -->\n            <div class=\"group relative z-10 opacity-75 hover:opacity-100 transition-opacity duration-300\">\n                <div class=\"w-24 h-24 mx-auto glass-card rounded-xl flex items-center justify-center border-t border-l border-[#ccff00]/30 group-hover:border-[#ccff00] transition-colors duration-500 mb-8 relative overflow-hidden bg-black/60\">\n                    <span class=\"font-mono text-[10px] text-gray-400 absolute top-2 left-2\">STEP 02</span>\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"#ffffff\" class=\"w-8 h-8 group-hover:scale-110 transition-transform duration-300\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 17.25v1.007a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0ZM18.75 21a3.75 3.75 0 100-7.5 3.75 3.75 0 000 7.5Zm4.997-7.5a.625.625 0 11-1.25 0 .625.625 0 011.25 0Z\" />\n                    </svg>\n                </div>\n                <h3 class=\"text-xl font-bold mb-4 text-white group-hover:text-[#ccff00] transition-colors\">Unleash Velocity</h3>\n                <p class=\"text-gray-500 leading-relaxed group-hover:leading-tight transition-all duration-300 max-w-xs mx-auto\">\n                    Physical dock unlock. Our 48V brushless motors engage instantly for up to 25mph top speed.\n                </p>\n            </div>\n\n            <!-- Step 3 -->\n            <div class=\"group relative z-10 opacity-75 hover:opacity-100 transition-opacity duration-300\">\n                <div class=\"w-24 h-24 mx-auto glass-card rounded-xl flex items-center justify-center border-t border-l border-[#ccff00]/30 group-hover:border-[#ccff00] transition-colors duration-500 mb-8 relative overflow-hidden bg-black/60\">\n                    <span class=\"font-mono text-[10px] text-gray-400 absolute top-2 left-2\">STEP 03</span>\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"#ffffff\" class=\"w-8 h-8 group-hover:scale-110 transition-transform duration-300\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6.75 9l12-5.25m0 0L14.25 18 6.75 9zM6.75 9v3.75c0 .625-.5 1.125-1.125 1.125H3a.75.75 0 01-.75-.75V8.625A.75.75 0 014.375 8h2.99c.625 0 1.125.5 1.125 1.125z\" />\n                    </svg>\n                </div>\n                <h3 class=\"text-xl font-bold mb-4 text-white group-hover:text-[#ccff00] transition-colors\">Park & Earn</h3>\n                <p class=\"text-gray-500 leading-relaxed group-hover:leading-tight transition-all duration-300 max-w-xs mx-auto\">\n                    Ride anywhere. Return to any station. Your credit balance updates in real-time.\n                </p>\n            </div>\n\n        </div>\n    </section>\n\n    <!-- Pricing Section -->\n    <section id=\"pricing\" class=\"py-24 relative overflow-hidden\">\n        \n        <!-- Decoration -->\n        <div class=\"absolute top-0 left-[20%] w-full h-px bg-gradient-to-r from-transparent via-[#ccff00]/50 to-transparent\"></div>\n\n        <div class=\"max-w-7xl mx-auto px-6 md:px-12\">\n            \n            <!-- Header -->\n            <div class=\"text-center mb-20\">\n                <h4 class=\"font-mono text-[#ccff00] mb-3 uppercase tracking-widest text-sm\">Transparent Rates</h4>\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 gradient-text\">Tiered Velocity</h2>\n                <p class=\"text-gray-400 max-w-xl mx-auto\">No hidden fees. Cancel anytime. Subscription starts instantly.</p>\n            </div>\n\n            <!-- Cards Grid -->\n            <div class=\"grid md:grid-cols-3 gap-8 items-start relative z-10\">\n                \n                <!-- Starter Card -->\n                <div class=\"glass-card p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-500 group\">\n                    <h3 class=\"text-xl font-bold mb-4 flex justify-between text-white\">\n                        STAGGER\n                        <span class=\"font-mono text-xs border border-gray-700 px-2 py-1 rounded\">Essential</span>\n                    </h3>\n                    <div class=\"mb-6\">\n                        <span class=\"block font-mono text-sm text-gray-400 mb-1\">$0.50 / mile</span>\n                        <span class=\"text-4xl font-bold tracking-tighter group-hover:text-[#ccff00] transition-colors duration-300\">Ride as you go.</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-8 text-sm text-gray-400\">\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> All Stations Access</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> GPS Tracking</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-gray-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Daily Insurance</li>\n                    </ul>\n                </div>\n\n                <!-- Pro Card (Highlighted) -->\n                <div class=\"glass-card p-8 rounded-2xl border-[#ccff00] shadow-[0_0_35px_rgba(204,255,0,0.1)] hover:-translate-y-6 transition-transform duration-500 relative group bg-gradient-to-b from-[#101010] to-black\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-16 h-8 bg-[#ccff00] flex items-center justify-center font-mono text-xs text-black uppercase tracking-wider rounded-sm overflow-hidden shadow-lg animate-pulse\">\n                        <span class=\"animate-marquee whitespace-nowrap\">Most Popular</span>\n                    </div>\n                    \n                    <h3 class=\"text-xl font-bold mb-4 flex justify-between text-white group-hover:text-[#ccff00] transition-colors duration-300\">\n                        VELOCE PRO\n                        <span class=\"font-mono text-xs border border-[#ccff00]/50 px-2 py-1 rounded bg-black/60\">Recommended</span>\n                    </h3>\n                    <div class=\"mb-6\">\n                        <span class=\"block font-mono text-sm text-gray-400 mb-1\">$89 / month</span>\n                        <span class=\"text-5xl font-bold tracking-tighter group-hover:text-[#ccff00] transition-colors duration-300\">Flat Rate.</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-8 text-sm text-gray-400\">\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Unlimited Mileage</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Priority Dock Selection</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Accident Waiver</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Faster Unlock Times</li>\n                    </ul>\n                    <button class=\"w-full py-4 bg-[#ccff00] text-black font-bold uppercase tracking-widest hover:bg-white transition-colors duration-300 shadow-[0_0_15px_rgba(204,255,0,0.4)]\">\n                        Get Pro Access\n                    </button>\n                </div>\n\n                <!-- Unlimited Card -->\n                <div class=\"glass-card p-8 rounded-2xl hover:-translate-y-2 transition-transform duration-500 group\">\n                    <h3 class=\"text-xl font-bold mb-4 flex justify-between text-white\">\n                        GHOST\n                        <span class=\"font-mono text-xs border border-gray-700 px-2 py-1 rounded\">Experimental</span>\n                    </h3>\n                    <div class=\"mb-6\">\n                        <span class=\"block font-mono text-sm text-gray-400 mb-1\">$250 / lifetime</span>\n                        <span class=\"text-4xl font-bold tracking-tighter group-hover:text-[#ccff00] transition-colors duration-300\">One-time fee.</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-8 text-sm text-gray-400\">\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Lifetime Subscription</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Private Dock Reservation</li>\n                        <li class=\"flex items-center gap-3\"><svg class=\"w-4 h-4 text-[#ccff00]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg> Custom Paint Jobs</li>\n                    </ul>\n                </div>\n\n            </div>\n        </div>\n    </section>\n\n    <!-- Social Proof Section -->\n    <section id=\"join\" class=\"py-20 relative border-t border-gray-900\">\n        \n        <div class=\"max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-10\">\n            \n            <!-- Text Side -->\n            <div class=\"flex-1 space-y-6\">\n                <h2 class=\"text-sm font-mono text-[#ccff00] uppercase tracking-widest mb-2\">Community Status</h2>\n                <h3 class=\"text-3xl md:text-4xl font-bold text-white leading-tight\">Join 14,209 riders redefining the city.</h3>\n            </div>\n\n            <!-- Review Slider (Static for Landing Page) -->\n            <div class=\"flex-1 w-full glass-card p-8 rounded-xl relative overflow-hidden border-[#ccff00]/20\">\n                \n                <!-- Stars Animation Wrapper -->\n                <div class=\"flex justify-center gap-3 mb-6 text-[#ccff00] opacity-90 hover:opacity-100 transition-opacity\" id=\"star-container\">\n                    <!-- JS will populate stars here -->\n                </div>\n\n                <!-- Quote -->\n                <p class=\"text-lg md:text-xl italic font-light text-gray-300 mb-8 leading-relaxed\">\n                    \"The unlock latency is unnoticeable. It feels like magic technology. Finally, a way to cross the downtown grid without a car.\"\n                </p>\n\n                <!-- User Avatar & Info -->\n                <div class=\"flex items-center gap-4\">\n                    <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Alex&backgroundColor=f5f6fa\" alt=\"User\" class=\"w-12 h-12 rounded-full border border-gray-600 shadow-lg hover:scale-110 transition-transform cursor-crosshair\">\n                    <div>\n                        <h4 class=\"font-bold text-white\">Alex R.</h4>\n                        <div class=\"flex items-center gap-2 mt-1 text-xs font-mono text-green-500\">\n                            <span>Sarah</span> \u2022 <span>Mike</span> \u2022 <span>Tony</span>\n                        </div>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"border-t border-gray-800 pt-16 pb-8 bg-[#020203]\">\n        <div class=\"max-w-screen-xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start gap-8\">\n            \n            <!-- Brand -->\n            <div>\n                <a href=\"#\" class=\"text-2xl font-bold tracking-tighter hover:text-[#ccff00] transition-colors relative group\" onmouseover=\"this.classList.add('glow-hover')\" onmouseout=\"this.classList.remove('glow-hover')\">\n                    VELOCE<span class=\"text-xs align-top ml-1 opacity-50\">///</span>\n                </a>\n                <p class=\"mt-4 text-gray-600 max-w-xs leading-relaxed\">\n                    Designed for the fast forward. Built to endure.\n                </p>\n            </div>\n\n            <!-- Links -->\n            <nav class=\"flex gap-8 md:gap-12 font-mono text-sm uppercase tracking-wider text-gray-500\">\n                <a href=\"#\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('how')\">How it Works</a>\n                <a href=\"#\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('pricing')\">Pricing</a>\n                <a href=\"#\" class=\"hover:text-[#ccff00] transition-colors relative group after:absolute after:bottom-full after:left-1/2 after:w-max after:-translate-x-1/2 after:h-0.5 after:bg-white after:transition-all after:duration-300 hover:after:h-[2px]\" onclick=\"scrollToId('join')\">Terms</a>\n            </nav>\n\n            <!-- Socials -->\n            <div class=\"flex gap-4\">\n                <a href=\"#\" class=\"w-10 h-10 rounded-full border border-gray-800 flex items-center justify-center hover:bg-[#ccff00] hover:border-[#ccff00] transition-all duration-300\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 12h2v3h6v-6h-2v-3h-4v6z\"/></svg>\n                </a>\n            </div>\n        </div>\n\n        <div class=\"mt-12 flex justify-between items-center text-xs font-mono text-gray-700\">\n            <span>&copy; 2024 VELOCE SYSTEMS</span>\n            <div class=\"flex gap-6\">\n                <a href=\"#\" onclick=\"return false\" class=\"hover:text-[#ccff00]\">PRIVACY</a>\n                <a href=\"#\" onclick=\"return false\" class=\"hover:text-[#ccff00]\">SYSTEMS</a>\n            </div>\n        </div>\n    </footer>\n\n    <!-- JavaScript Interactions -->\n    <script>\n        // Custom Cursor Logic\n        const cursorDot = document.querySelector('.cursor-dot');\n        const cursorOutline = document.querySelector('.cursor-outline');\n\n        window.addEventListener('mousemove', (e) => {\n            const posX = e.clientX;\n            const posY = e.clientY;\n\n            // Dot follows instantly\n            cursorDot.style.left = `${posX}px`;\n            cursorDot.style.top = `${posY}px`;\n\n            // Outline follows with slight delay/animation\n            cursorOutline.animate({\n                left: `${posX}px`,\n                top: `${posY}px`\n            }, { duration: 500, fill: \"forwards\" });\n        });\n\n        // Hover Effect for Links and Buttons\n        function createHoverEffect() {\n            const dot = document.querySelector('.cursor-dot');\n            const outline = document.querySelector('.cursor-outline');\n            \n            dot.style.transform = 'translate(-50%, -50%) scale(2.5)';\n            outline.style.opacity = '1'; // Make border visible\n        }\n\n        function clearHoverEffect() {\n            const dot = document.querySelector('.cursor-dot');\n            const outline = document.querySelector('.cursor-outline');\n            \n            setTimeout(() => {\n                dot.style.transform = 'translate(-50%, -50%) scale(1)';\n                outline.style.opacity = '0.7'; // Reset to default alpha\n            }, 10);\n        }\n\n        // Smooth Scroll for Anchor Links\n        function scrollToId(id) {\n            const element = document.getElementById(id);\n            if (element) {\n                window.scrollTo({\n                    top: element.offsetTop,\n                    behavior: 'smooth'\n                });\n            }\n        }\n\n        // Generate Stars dynamically for the review section\n        const starsContainer = document.getElementById('star-container');\n        const starIcons = ['\u2605', '\u2606'];\n        \n        for(let i=0; i<5; i++) {\n            const starSpan = document.createElement('span');\n            starSpan.classList.add(i < 4 ? 'text-[#ccff00]' : 'text-gray-600'); // Neon if rated, gray if empty\n            \n            starSpan.innerHTML = i === 3 || i===2 ? '<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>' : '';\n            \n            starsContainer.appendChild(starSpan);\n        }\n\n        // Simple scroll reveal animation\n        const observerOptions = {\n            threshold: 0.1,\n            rootMargin: \"0px\"\n        };\n\n        const observer = new IntersectionObserver((entries) => {\n            entries.forEach(entry => {\n                if (entry.isIntersecting) {\n                    entry.target.classList.add('animate-fade-in-up');\n                    // You can add more CSS classes here for complex reveals\n                }\n            });\n        }, observerOptions);\n\n        document.querySelectorAll('.glass-card, h1, .hero').forEach(el => {\n            observer.observe(el);\n        });\n    </script>\n</body>\n</html>"
  },
